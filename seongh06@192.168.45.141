# Docker MySQL
MYSQL_ROOT_PASSWORD=my_super_secret_password_1234

# Spring DataSource
DB_URL=jdbc:mysql://localhost:3306/reborn?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&rewriteBatchedStatements=true
DB_USERNAME=root
DB_PASSWORD=my_super_secret_password_1234

# Spring JPA
SQL_INIT_MODE=never
JPA_DDL_AUTO=none

# JWT
JWT_SECRET=reborn-local-dev-secret-key-must-be-at-least-256-bits-long-for-hs256
JWT_ACCESS_TOKEN_EXPIRY=3600000
JWT_REFRESH_TOKEN_EXPIRY=1209600000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS S3 (dev — 미사용 시 빈 값 유지)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=reborn-dev

# Slack
SLACK_WEBHOOK_URL=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- FCM (Firebase Admin SDK) ----
FCM_
