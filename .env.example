# ================================================
# ReBorn — 환경변수 템플릿
# .env.example 을 복사하여 .env 파일로 만들어 사용
# .env 는 절대 커밋하지 않습니다
# ================================================

# ---- Docker MySQL ----
MYSQL_ROOT_PASSWORD=

# ---- Spring DataSource ----
DB_URL=jdbc:mysql://localhost:3306/reborn?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&rewriteBatchedStatements=true
DB_USERNAME=root
DB_PASSWORD=

# ---- Spring JPA ----
# 초기 스키마 적용: always / never
SQL_INIT_MODE=never
# JPA DDL: none / validate / update / create / create-drop
JPA_DDL_AUTO=none

# ---- JWT ----
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRY=3600000
JWT_REFRESH_TOKEN_EXPIRY=1209600000

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- AWS S3 ----
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=reborn-dev

# ---- Slack Webhook ----
SLACK_WEBHOOK_URL=

# ---- FCM (Firebase Admin SDK) ----
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성으로 받은 JSON을 base64로 인코딩해서 넣기
# (예: base64 -w0 service-account.json)
FCM_SERVICE_ACCOUNT_KEY_BASE64=

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000
